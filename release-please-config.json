{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "package-name": "bailiff",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        { "type": "yaml", "path": "apm.yml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "apm.yml", "jsonpath": "$.marketplace.packages[0].version" },
        { "type": "yaml", "path": "packages/bailiff/apm.yml", "jsonpath": "$.version" },
        { "type": "json", "path": "packages/bailiff/.claude-plugin/plugin.json", "jsonpath": "$.version" },
        { "type": "json", "path": ".claude-plugin/marketplace.json", "jsonpath": "$.plugins[0].version" }
      ]
    }
  },
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "chore", "section": "Miscellaneous", "hidden": true }
  ]
}
